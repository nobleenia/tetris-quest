{
  "name": "stackr-quest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A block-stacking puzzle adventure with 100+ levels, boss fights, and power-ups. Mobile-first PWA built with vanilla JS.",
  "author": "noble",
  "license": "Apache-2.0",
  "keywords": [
    "puzzle",
    "game",
    "pwa",
    "mobile",
    "block-stacking",
    "adventure",
    "vanilla-js"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\""
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "tone": "^15.1.22"
  }
}
